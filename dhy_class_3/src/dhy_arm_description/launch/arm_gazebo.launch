<launch>

    <!-- 加载机械臂 URDF 为 ROS 参数 -->
    <param name="robot_description" command="cat $(find dhy_arm_description)/urdf/arm.urdf"/>

    <!-- 启动 Gazebo 空世界 -->
    <include file="$(find gazebo_ros)/launch/empty_world.launch">
        <arg name="paused" value="false"/>
        <arg name="use_sim_time" value="true"/>
        <arg name="gui" value="true"/>
        <arg name="headless" value="false"/>
        <arg name="debug" value="false"/>
    </include>

    <!-- 将机械臂模型加载到 Gazebo 物理世界 -->
    <node name="spawn_model" pkg="gazebo_ros" type="spawn_model"
          args="-urdf -model dhy_arm -x 0.0 -y 0.0 -z 0.0 -param robot_description"
          output="screen"/>

    <!-- 发布机器人 TF 变换 -->
    <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher"
          output="screen">
        <param name="publish_frequency" type="double" value="50.0"/>
    </node>

    <!-- 加载关节状态控制器配置并启动 -->
    <rosparam file="$(find dhy_arm_description)/config/joint_state.yaml" command="load"/>
    <node name="joint_state_spawner" pkg="controller_manager" type="spawner"
          respawn="false" output="screen" ns="/"
          args="joint_state_controller"/>

    <!-- 加载机械臂控制器配置并启动 -->
    <rosparam file="$(find dhy_arm_description)/config/arm_controllers.yaml" command="load"/>
    <node name="arm_controller_spawner" pkg="controller_manager" type="spawner"
          respawn="false" output="screen" ns="/"
          args="arm_joint_controller claw_joint_1_controller claw_joint_2_controller"/>

</launch>
